# 必填：你的 API key（直连 Anthropic 用官方 key；走代理用代理的 master key）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# 可选：走代理（LiteLLM / 兼容服务）。填代理根地址，SDK 会请求 {base_url}/v1/messages，
# 由代理翻译成 DeepSeek / Qwen / OpenAI 等后端。不填=直连 Anthropic。
# 例：http://localhost:4000 （本地 LiteLLM proxy）
# ANTHROPIC_BASE_URL=http://localhost:4000

# 可选：输出语言 zh/en/ja/es/de（不设则按系统语言自动检测，默认 zh；会话中 /lang 可切换）
# OUTPUT_LANG=zh

# 可选：模型名。直连用 sonnet/opus/haiku 或 claude-* 完整 id；走代理则填代理里的模型名
# （如 deepseek-chat、qwen-max）。默认 claude-sonnet-5。
# MODEL=claude-sonnet-5

# 可选：Unpaywall 找开放获取 PDF 用的联系邮箱（建议填你自己的真实邮箱）
# UNPAYWALL_EMAIL=your-name@your-school.edu
